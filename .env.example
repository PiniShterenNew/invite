# --- Database ---
# Runtime connection: use Supabase Transaction pooler (port 6543) on Vercel.
DATABASE_URL="file:./dev.db"
# Migrations: use Supabase Session pooler (port 5432). Not needed for local SQLite.
DIRECT_URL=""

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# The canonical URL of the app (no trailing slash)
AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# --- Google OAuth (optional in dev; required for "Sign in with Google" in prod) ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (optional until a sending domain is available) ---
# Create an API key at https://resend.com/api-keys and verify a sending domain.
# When empty, dev mode writes emails to .dev-mailbox/ and prints magic links to the console.
RESEND_API_KEY=""
EMAIL_FROM="באים? <no-reply@example.com>"

# --- Cron protection ---
# Random string; Vercel Cron must send it as Authorization: Bearer {CRON_SECRET}
CRON_SECRET=""

# --- Supabase Storage (production) ---
# Keep the service-role key server-only. Never prefix it with NEXT_PUBLIC_.
SUPABASE_URL=""
SUPABASE_SECRET_KEY=""
SUPABASE_STORAGE_BUCKET="event-images"
